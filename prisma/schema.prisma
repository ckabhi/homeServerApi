generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
}

model User {
  id        String    @id @default(uuid(7))
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
  todos     Todo[]

  @@map("users")
}

model Session {
  id           String   @id @default(uuid(7))
  sessionId    String
  refreshToken String   @db.Text
  deviceType   String?  @db.VarChar(10)
  ipAddress    String?
  userAgent    String?  @db.VarChar(20)
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Todo {
  id          String  @id @default(uuid(7))
  title       String
  description String? @db.Text
  status      String  @default("new") // new, active, completed, blocked, backlog
  order       Int     @default(0)

  // Dates
  startDate DateTime?
  endDate   DateTime?

  // Visuals

  color       String?
  // tags              Json? // POST-MIGRATION: Removed in favor of relation
  // tags              Tag[] // Implicit relation removed
  tags        TodoTag[]
  isImportant Boolean   @default(false)

  // Recurrence
  isRecurring       Boolean @default(false)
  recurrencePattern String?
  parentId          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("todos")
}

model Tag {
  id    String    @id @default(uuid(7))
  name  String    @unique
  todos TodoTag[]

  @@map("tags")
}

model TodoTag {
  todoId String
  todo   Todo   @relation(fields: [todoId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([todoId, tagId])
  @@map("todo_tags")
}

// =======================
// FILE UPLOAD MODULE
// =======================

model FileUploadSession {
  id           String    @id @default(uuid(7))
  userId       String    // Value reference only, no @relation
  presignedUrl String    @db.Text
  objectKey    String
  displayName  String?
  systemFileName String?
  folderPath   String?
  parentFolderId String?
  isSharedFile Boolean   @default(false)
  bucketName   String
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  isUsed       Boolean   @default(false)
  isRevoked    Boolean   @default(false)
  completedAt  DateTime?

  // Multipart upload fields
  uploadId     String?   // S3/MinIO multipart upload ID
  isMultipart  Boolean   @default(false)
  totalChunks  Int?
  chunkSize    Int?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@map("file_upload_sessions")
}

model FileMetadata {
  id          String   @id @default(uuid(7))
  userId      String   // Value reference only, no @relation
  fileName    String
  displayName String
  systemFileName String
  objectKey   String   @unique
  bucketName  String
  fileSize    BigInt
  mimeType    String
  folderPath  String   @default("")
  parentFolderId String?
  isSharedFile Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  imageMetadata FileImageMetadata?

  @@index([userId, parentFolderId])
  @@index([userId, isSharedFile])
  @@index([isSharedFile, parentFolderId])
  @@index([displayName])
  @@map("file_metadata")
}

model FolderPermission {
  id          String   @id @default(uuid(7))
  userId      String   // Value reference only, no @relation
  folderName  String
  folderPath  String
  parentPath  String   @default("")
  parentFolderId String?
  isShared    Boolean  @default(false)
  isDeleted   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Self-relation for hierarchy
  parentFolder    FolderPermission?  @relation("FolderHierarchy", fields: [parentFolderId], references: [id], onDelete: SetNull)
  childFolders    FolderPermission[] @relation("FolderHierarchy")

  @@unique([userId, folderPath, isShared])
  @@index([userId])
  @@index([parentFolderId])
  @@index([isShared])
  @@map("folder_permissions")
}

model FileChunkUpload {
  uploadId       String    @id
  userId         String    // Value reference only, no @relation
  objectKey      String
  totalChunks    Int
  uploadedChunks Int       @default(0)
  fileSize       BigInt
  mimeType       String
  status         String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, FAILED, EXPIRED
  expiresAt      DateTime
  completedAt    DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@map("file_chunk_uploads")
}

model FileImageMetadata {
  id                 String   @id @default(uuid(7))
  fileMetadataId     String   @unique
  thumbnailObjectKey String?
  previewObjectKey   String?
  width              Int?
  height             Int?
  orientation        Int?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  fileMetadata       FileMetadata @relation(fields: [fileMetadataId], references: [id], onDelete: Cascade)

  @@map("file_image_metadata")
}

model FileAuditLog {
  id         String   @id @default(uuid(7))
  userId     String   // Value reference only, no @relation
  operation  String   // UPLOAD, DOWNLOAD, DELETE, RENAME, CREATE_FOLDER
  objectKey  String?
  ipAddress  String?
  userAgent  String?
  status     String   // SUCCESS, FAILED
  details    String?  @db.Text

  createdAt  DateTime @default(now())

  @@index([userId, operation, createdAt])
  @@map("file_audit_logs")
}
